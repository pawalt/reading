---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const spikes = (await getCollection("spikes")).sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime()
);
---

<BaseLayout title="Reading">
  <section class="landing-hero">
    <p class="eyebrow">Reading spikes</p>
    <h1>Latest spikes.</h1>
    <p class="hero-summary">
      Team-focused reading notes with short overviews, annotated sources, and local PDFs when they
      are worth mirroring.
    </p>
  </section>

  <section class="section-block">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Recent reading</h2>
    </div>
    <div class="spike-row-list">
      {spikes.map((entry) => (
        <a class="spike-row" href={`/spikes/${entry.slug}/`}>
          <div class="spike-row-main">
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
          </div>
          <div class="spike-row-meta">
            <span>{entry.data.updatedAt.toISOString().slice(0, 10)}</span>
            <span>{entry.data.sourceCount} sources</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
